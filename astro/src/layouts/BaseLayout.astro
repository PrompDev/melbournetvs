---
/**
 * BaseLayout.astro
 * -----------------
 * Thin compatibility layer over MarketingLayout so every layout that still
 * calls `<BaseLayout title=... description=... image=... canonical=...>`
 * keeps working while automatically inheriting the full homepage chrome
 * (Header with mega-menu, Footer, AI chat widget, marketing.css, JSON-LD).
 *
 * Prefer MarketingLayout for new pages — it exposes the richer prop surface
 * (ogImage, keywords, jsonLd, noindex). This file exists only to keep older
 * layouts from needing individual refactors.
 */
import MarketingLayout from "~/layouts/MarketingLayout.astro";

interface Props {
  title: string;
  description: string;
  image?: string;
  canonical?: string;
  keywords?: string;
  noindex?: boolean;
  /** Per-page JSON-LD. Passed straight through to MarketingLayout. */
  jsonLd?: Record<string, any> | Record<string, any>[];
  /** Per-page body class hook, forwarded to MarketingLayout. */
  bodyClass?: string;
}

const {
  title,
  description,
  image,
  canonical,
  keywords,
  noindex,
  jsonLd,
  bodyClass,
} = Astro.props;
---
<MarketingLayout
  title={title}
  description={description}
  canonical={canonical}
  ogImage={image}
  keywords={keywords}
  noindex={noindex}
  jsonLd={jsonLd}
  bodyClass={bodyClass}
>
  <slot />
</MarketingLayout>
