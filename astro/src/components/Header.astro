<style>
  .brand-wordmark{font-family:Inter,sans-serif;font-size:21px;font-weight:900;letter-spacing:-1.25px;color:#fff;line-height:1}
  .brand-wordmark strong{font-weight:900}.brand-wordmark span{color:#5b50ec;font-size:1.18em;font-weight:900;letter-spacing:-1.7px}
  body.page-subpage .brand-wordmark,.site-header.is-menu-open .brand-wordmark{color:#0a0a0c}
  .header-text-link{display:inline-flex;align-items:center;color:#fff;font-size:13px;font-weight:500;white-space:nowrap}
  body.page-subpage .header-text-link,.site-header.is-menu-open .header-text-link{color:#1a1a1a}
  .mobile-drawer-wordmark{font-family:Inter,sans-serif;font-size:22px;font-weight:900;letter-spacing:-1.2px;color:#fff;margin-bottom:14px}
  .mobile-drawer-wordmark span{color:#5b50ec;font-size:1.18em}
  @media(max-width:1200px){.header-text-link{display:none}}
</style>

<script is:inline>
  (() => {
    const button = document.getElementById('hamburgerBtn');
    const menu = document.getElementById('mobileMenu');
    const backdrop = document.getElementById('mobileMenuBackdrop');
    const close = document.getElementById('mobileMenuClose');
    if (!button || !menu || !backdrop || !close) return;

    const setOpen = (open) => {
      button.classList.toggle('is-open', open);
      menu.classList.toggle('active', open);
      backdrop.classList.toggle('active', open);
      document.body.classList.toggle('menu-open', open);
      button.setAttribute('aria-expanded', String(open));
      menu.setAttribute('aria-hidden', String(!open));
    };

    button.addEventListener('click', () => setOpen(button.getAttribute('aria-expanded') !== 'true'));
    close.addEventListener('click', () => setOpen(false));
    backdrop.addEventListener('click', () => setOpen(false));
    document.addEventListener('keydown', (event) => { if (event.key === 'Escape') setOpen(false); });
  })();
</script>
